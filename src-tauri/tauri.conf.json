{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "sticky",
  "version": "1.0.1",
  "identifier": "com.kayden.sticky",
  "build": {
    "frontendDist": "../public"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "sticky",
        "width": 1100,
        "height": 720,
        "minWidth": 700,
        "minHeight": 500,
        "decorations": true,
        "resizable": true,
        "dragDropEnabled": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": false,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/leftlyk/sticky-app/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEZGRTZBMTE5N0ExOTQ2MUQKUldRZFJobDZHYUhtLy92RURscG1jSm1FOU1ITXpISlpnL0JoQSs5dVFJL2RiejZxYmV5ZFdBWmEK"
    }
  }
}
